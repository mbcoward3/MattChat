# Microsoft Entra ID (Azure AD)
# Found in: Entra admin center > App registrations > ChatKit Backend app > Overview
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_CLIENT_ID=your-chatkit-backend-client-id
ENTRA_CLIENT_SECRET=your-chatkit-backend-client-secret

# MCP Server app registration
# Scope format: api://<mcp-server-client-id>/mcp.tools
MCP_SERVER_SCOPE=api://your-mcp-server-client-id/mcp.tools
# Found in: Entra admin center > App registrations > MCP Server app > Overview
MCP_SERVER_CLIENT_ID=your-mcp-server-client-id

# OpenAI API key (for Agents SDK inference)
# Found at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
